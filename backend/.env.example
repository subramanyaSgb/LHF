# Database
DATABASE_URL=sqlite+aiosqlite:///./infrasense.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/infrasense

# Auth
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# Camera
CAMERA_MODE=mock
# mock = simulated thermal frames
# real = Micro-Epsilon TIM 8 SDK

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SMS (mock for now — logs to console)
SMS_GATEWAY_URL=
SMS_API_KEY=

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@infrasense.local

# PLC
PLC_HOST=192.168.1.50
PLC_PORT=502
PLC_POLL_INTERVAL_MS=1000
PLC_CONNECTION_TIMEOUT_MS=5000

# Recording
RECORDING_STORAGE_PATH=./recordings
RECORDING_MAX_FILE_SIZE_MB=5000
RECORDING_FRAME_RATE=25

# Retention
RETENTION_CLEAN_DAYS=7
RETENTION_FLAGGED_DAYS=90
RETENTION_AUTO_DELETE=true

# Reports
REPORT_STORAGE_PATH=./reports
REPORT_DAILY_TIME=06:00
REPORT_TIMEZONE=Asia/Kolkata
